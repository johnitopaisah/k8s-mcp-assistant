# Allowed namespaces, comma-separated.
# Leave empty to allow all namespaces (cluster-wide access).
K8S_ALLOWED_NAMESPACES=

# Read-only mode. Set to "true" to disable write operations.
K8S_READ_ONLY=true

# Optional explicit kubeconfig path. If not set, the application will use the default kubeconfig location.
KUBECONFIG_PATH=

# Optional fixed context name. If not set, the application will use the current context from the kubeconfig.
KUBE_CONTEXT=

# Optional fixed cluster name. If not set, the application will use the cluster from the kubeconfig context.
KUBE_CLUSTER=

# Optional fixed user name. If not set, the application will use the user from the kubeconfig context.
KUBE_USER=

# Optional fixed API server URL. If not set, the application will use the API server from the kubeconfig context.
KUBE_API_SERVER=

# Default number of log lines to fetch when viewing pod logs.
K8S_DEFAULT_LOG_TAIL_LINES=100

# Maximum number of log lines to fetch when viewing pod logs.
K8S_MAX_LOG_TAIL_LINES=1000
